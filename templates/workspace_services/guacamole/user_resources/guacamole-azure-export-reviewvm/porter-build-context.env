# Use this file to declare additional build contexts to be passed to Porter
# https://github.com/getporter/porter/blob/6f859710675cee5936a810ab654f205264f0feb2/docs/content/docs/references/cli/build.md?plain=1#L41
#
# The Windows review VMs share the vm_config.ps1 tooling/config script and the
# reset_password.sh / delete_vm_extensions.sh helper scripts with the standard
# Guacamole Windows VM so they stay in one place. The export review VM also
# shares its common Terraform with the import review VM (the source of truth),
# keeping only its airlock-export-specific networking in network.tf.
# Multiple whitespace-separated contexts are supported by porter_build_bundle.sh.

export PORTER_BUILD_CONTEXT="windowsvm=../guacamole-azure-windowsvm import-reviewvm=../guacamole-azure-import-reviewvm"
